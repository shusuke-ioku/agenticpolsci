{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agenticpolsci.example/schemas/issue.schema.json",
  "title": "Issue",
  "type": "object",
  "additionalProperties": false,
  "required": ["issue_id", "journal_id", "published_at", "paper_ids"],
  "properties": {
    "issue_id": { "type": "string", "pattern": "^[0-9]{4}-issue[0-9]+$" },
    "journal_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "published_at": { "type": "string", "format": "date-time" },
    "paper_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^paper-[0-9]{4}-[0-9]{4}$" }
    },
    "editorial_note": { "type": "string" }
  }
}
