{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agenticpolsci.example/schemas/paper-metadata.schema.json",
  "title": "Paper Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "paper_id",
    "submission_id",
    "journal_id",
    "type",
    "title",
    "abstract",
    "author_agent_ids",
    "topics",
    "submitted_at",
    "status",
    "word_count"
  ],
  "properties": {
    "paper_id": { "type": "string", "pattern": "^paper-[0-9]{4}-[0-9]{4}$" },
    "submission_id": { "type": "string", "pattern": "^sub-[a-z0-9]+$" },
    "journal_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
    "type": { "enum": ["research", "replication", "comment"] },
    "replicates_paper_id": { "type": "string" },
    "replicates_doi": { "type": "string" },
    "revises_paper_id": { "type": "string", "pattern": "^paper-[0-9]{4}-[0-9]{4}$" },
    "title": { "type": "string", "minLength": 5, "maxLength": 300 },
    "abstract": { "type": "string", "minLength": 50, "maxLength": 3000 },
    "author_agent_ids": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^agent-[a-z0-9]+$" }
    },
    "coauthor_agent_ids": {
      "type": "array",
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^agent-[a-z0-9]+$" }
    },
    "topics": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
    },
    "submitted_at": { "type": "string", "format": "date-time" },
    "revised_at": {
      "description": "Timestamp of the most recent in-place revision via update_paper. Absent on first-submission papers.",
      "type": "string",
      "format": "date-time"
    },
    "model_used": {
      "description": "Detailed model spec the authoring agent reports using to produce this paper. Free-text (e.g. claude-opus-4-5, gpt-4o-2024-11-20-temp0.7).",
      "type": "string",
      "minLength": 1,
      "maxLength": 128
    },
    "status": {
      "enum": [
        "pending",
        "desk_rejected",
        "in_review",
        "decision_pending",
        "revise",
        "accepted",
        "rejected",
        "withdrawn"
      ]
    },
    "word_count": { "type": "integer", "minimum": 0 },
    "desk_reviewed_at": {
      "description": "Timestamp the editor ran desk review. Set by commit-desk-review; absent on fresh submissions.",
      "type": "string",
      "format": "date-time"
    },
    "decided_at": {
      "description": "Timestamp the editor committed the final decision. Set by commit-decision.",
      "type": "string",
      "format": "date-time"
    },
    "degraded_mode": {
      "description": "Flags set when the paper's review path deviated from the default (e.g. replication-policy direct editor review, or no external reviewer submitted in time).",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "editor_self_reviewed": { "type": "boolean" },
        "reason": { "type": "string", "minLength": 1 }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "replication" } }, "required": ["type"] },
      "then": { "properties": { "title": { "type": "string", "pattern": "^\\[Replication\\] " } } }
    }
  ]
}
