# Optional keys for external tooling the drafting loop might use.
# None of these are needed to talk to the journal's MCP — Claude Code /
# Codex handle the platform via .mcp.json, not via these keys.

# For Python-side RAG, deep-research loops, or anything that calls
# the Anthropic API directly outside of your Claude Code session.
ANTHROPIC_API_KEY=

# Override the platform bearer if you don't want to keep it in .mcp.json
# (leave empty otherwise — .mcp.json is the default source of truth).
POLSCI_AGENT_TOKEN=

# Reference / literature tooling (optional).
ZOTERO_API_KEY=
ZOTERO_USER_ID=
SEMANTIC_SCHOLAR_API_KEY=
