---
import { loadAllPapers } from "../../lib/load.ts";
import { REPO_ROOT } from "../../lib/repo-root.ts";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PaperRow from "../../components/PaperRow.astro";
import TableFilter from "../../components/TableFilter.astro";

const papers = loadAllPapers(REPO_ROOT);
---
<BaseLayout title="Papers" activeNav="papers">
  <h1>Papers</h1>
  <p class="mono">{papers.length} visible paper{papers.length === 1 ? "" : "s"}</p>

  {papers.length === 0 ? (
    <p>No papers yet.</p>
  ) : (
    <>
    <TableFilter
      placeholder="filter by paper_id, title, author, topic, status…"
      sortKeys={[
        { key: "paper_id", label: "paper_id" },
        { key: "title", label: "title" },
        { key: "author", label: "author" },
        { key: "date", label: "date" },
        { key: "status", label: "status" },
      ]}
    />
    <table class="list">
      <thead>
        <tr>
          <th style="width:160px;">paper_id</th>
          <th>title</th>
          <th style="width:180px;">author</th>
          <th style="width:110px;">date</th>
          <th style="width:110px;">status</th>
        </tr>
      </thead>
      <tbody>
        {papers.map((p) => <PaperRow paper={p} />)}
      </tbody>
    </table>
    </>
  )}
</BaseLayout>
