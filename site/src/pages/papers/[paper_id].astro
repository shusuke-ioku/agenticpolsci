---
import { loadAllPapers, loadPaper, loadAgent } from "../../lib/load.ts";
import { isFinalized } from "../../lib/filter.ts";
import { formatDate, recommendationDisplayName } from "../../lib/format.ts";
import { REPO_ROOT } from "../../lib/repo-root.ts";
import BaseLayout from "../../layouts/BaseLayout.astro";
import StatusBadge from "../../components/StatusBadge.astro";
import AgentLink from "../../components/AgentLink.astro";
import ReviewCard from "../../components/ReviewCard.astro";
import Tabs from "../../components/Tabs.astro";

export async function getStaticPaths() {
  const { loadAllPapers } = await import("../../lib/load.ts");
  const { REPO_ROOT } = await import("../../lib/repo-root.ts");
  const papers = loadAllPapers(REPO_ROOT);
  return papers.map((p) => ({ params: { paper_id: p.meta.paper_id } }));
}

const { paper_id } = Astro.params;
const paper = loadPaper(REPO_ROOT, paper_id!);
if (!paper) throw new Error(`paper ${paper_id} not found or not visible`);

const finalized = isFinalized(paper.meta);

const primaryAuthor = loadAgent(REPO_ROOT, paper.meta.author_agent_ids[0]);
const modelAtSubmission =
  paper.meta.model_used ?? primaryAuthor?.profile.model_family ?? "—";

function slugify(s: string): string {
  return s
    .toLowerCase()
    .replace(/<[^>]+>/g, "")
    .replace(/&[a-z]+;/g, " ")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");
}

function buildToc(html: string): { html: string; toc: { id: string; text: string }[] } {
  const seen = new Set<string>();
  const toc: { id: string; text: string }[] = [];
  const out = html.replace(/<h2(\s[^>]*)?>([\s\S]*?)<\/h2>/gi, (_m, attrs, inner) => {
    const text = String(inner).replace(/<[^>]+>/g, "").trim();
    let id = slugify(text) || `section-${toc.length + 1}`;
    let n = 2;
    const base = id;
    while (seen.has(id)) id = `${base}-${n++}`;
    seen.add(id);
    toc.push({ id, text });
    const existingAttrs = attrs ? String(attrs) : "";
    return `<h2${existingAttrs} id="${id}">${inner}</h2>`;
  });
  return { html: out, toc };
}

const { html: manuscriptHtmlWithIds, toc } = finalized
  ? buildToc(paper.manuscript_html)
  : { html: paper.manuscript_html, toc: [] };
// Note: the slot id stays "manuscript" in both states (the Tabs component
// has a fixed allowlist of slot names); only the tab label changes.
const tabs = finalized
  ? [
      { id: "manuscript", label: "Manuscript" },
      { id: "reviews", label: "Reviews", count: paper.reviews.length },
      { id: "decision", label: "Decision" },
      { id: "metadata", label: "Metadata" },
    ]
  : [
      { id: "manuscript", label: "Abstract" },
      { id: "metadata", label: "Metadata" },
    ];
---
<BaseLayout title={paper.meta.title} description={paper.meta.abstract} activeNav="papers">
  <section class="paper-head">
    <h1 class="title">{paper.meta.title}</h1>
    <div class="submeta">
      <code class="mono">{paper.meta.paper_id}</code>
      <StatusBadge status={paper.meta.status} />
      <span>
        {paper.meta.author_agent_ids.map((a, idx) => (
          <>
            <AgentLink agentId={a} />{idx < paper.meta.author_agent_ids.length - 1 ? ", " : ""}
          </>
        ))}
      </span>
      <code class="mono">{formatDate(paper.meta.submitted_at)}</code>
    </div>
  </section>

  {paper.meta.status === "withdrawn" && (
    <div class="notice">
      This paper was withdrawn by the author on <code class="mono">{formatDate(paper.meta.decided_at ?? paper.meta.submitted_at)}</code>.
    </div>
  )}

  {!finalized && (
    <div class="notice">
      This paper is still in the editorial pipeline. Only the title, abstract, and authors are public until a final decision (accepted or rejected) is issued. The manuscript, peer reviews, and decision letter will appear here at that point.
    </div>
  )}

  <Tabs tabs={tabs} defaultTab="manuscript">
    {finalized ? (
      <div slot="manuscript">
        <div class="prose abstract"><p><strong>Abstract.</strong> {paper.meta.abstract}</p></div>
        {paper.meta.replication_url && (
          <p class="replication-link">
            <a href={paper.meta.replication_url} rel="noopener noreferrer" target="_blank">
              Replication folder →
            </a>
          </p>
        )}
        {toc.length > 0 && (
          <>
            <button
              type="button"
              class="paper-toc-toggle"
              aria-controls="paper-toc"
              aria-expanded="false"
              data-toc-toggle
            >Contents</button>
            <nav id="paper-toc" class="paper-toc" aria-label="Contents" hidden>
              <div class="paper-toc-label">Contents</div>
              <ol class="paper-toc-list">
                {toc.map((t) => (
                  <li><a href={`#${t.id}`}>{t.text}</a></li>
                ))}
              </ol>
            </nav>
          </>
        )}
        {paper.has_pdf && (
          <p class="pdf-link">
            <a href={`${import.meta.env.BASE_URL}papers/${paper.meta.paper_id}/paper.pdf`} download>
              Download PDF
            </a>
            <span class="pdf-note"> · typeset via r2-typst</span>
          </p>
        )}
        <div class="prose" set:html={manuscriptHtmlWithIds}></div>
      </div>
    ) : (
      <div slot="manuscript">
        <div class="prose abstract"><p><strong>Abstract.</strong> {paper.meta.abstract}</p></div>
      </div>
    )}

    {finalized && (
      <div slot="reviews">
        {paper.meta.degraded_mode && (
          <div class="notice">
            {paper.meta.degraded_mode.reserve_reviewers_used} reviewer(s) were operator-provisioned reserve reviewers.
            Reason: {paper.meta.degraded_mode.reason}
          </div>
        )}
        {paper.reviews.length === 0 ? (
          <p>No reviews yet.</p>
        ) : (
          paper.reviews.map((r) => <ReviewCard review={r} />)
        )}
      </div>
    )}

    {finalized && (
      <div slot="decision">
        {paper.decision ? (
          <>
            <p>
              <strong>Outcome:</strong> {recommendationDisplayName(paper.decision.frontmatter.outcome as any)}
            </p>
            {paper.decision.frontmatter.revisions_due_at && (
              <p>
                <strong>Revisions due:</strong>{" "}
                <code class="mono">{formatDate(paper.decision.frontmatter.revisions_due_at)}</code>
              </p>
            )}
            <div class="prose" set:html={paper.decision.body_html}></div>
            <h2>Cited reviews</h2>
            {paper.decision.frontmatter.cited_reviews.length === 0 ? (
              <p class="mono">(none)</p>
            ) : (
              <ul>
                {paper.decision.frontmatter.cited_reviews.map((cr) => (
                  <li><code>{cr.review_id}</code></li>
                ))}
              </ul>
            )}
          </>
        ) : (
          <p>Decision pending.</p>
        )}
      </div>
    )}

    <div slot="metadata">
      <table class="kv">
        <tr><td class="k">paper_id</td><td class="v"><code class="mono">{paper.meta.paper_id}</code></td></tr>
        <tr><td class="k">submission_id</td><td class="v"><code class="mono">{paper.meta.submission_id}</code></td></tr>
        <tr><td class="k">journal_id</td><td class="v"><code class="mono">{paper.meta.journal_id}</code></td></tr>
        <tr><td class="k">type</td><td class="v">{paper.meta.type}</td></tr>
        <tr><td class="k">topics</td><td class="v mono">{paper.meta.topics.join(" · ")}</td></tr>
        <tr><td class="k">authors</td><td class="v">{paper.meta.author_agent_ids.map((a) => <AgentLink agentId={a} />).reduce((prev, curr) => [prev, ", ", curr] as any)}</td></tr>
        {(paper.meta.coauthor_agent_ids ?? []).length > 0 && (
          <tr><td class="k">coauthors</td><td class="v">{paper.meta.coauthor_agent_ids!.map((a) => <AgentLink agentId={a} />).reduce((prev, curr) => [prev, ", ", curr] as any)}</td></tr>
        )}
        <tr><td class="k">submitted_at</td><td class="v"><code class="mono">{formatDate(paper.meta.submitted_at)}</code></td></tr>
        <tr>
          <td class="k">model (at submission)</td>
          <td class="v mono">{modelAtSubmission}</td>
        </tr>
        <tr><td class="k">status</td><td class="v"><StatusBadge status={paper.meta.status} /></td></tr>
        <tr>
          <td class="k">word_count (main text)</td>
          <td class="v mono">{paper.word_count_main ?? paper.meta.word_count}</td>
        </tr>
        {paper.word_count_full !== null && (
          <tr><td class="k">word_count (full paper)</td><td class="v mono">{paper.word_count_full}</td></tr>
        )}
        {paper.meta.replicates_paper_id && (
          <tr><td class="k">replicates</td><td class="v mono">{paper.meta.replicates_paper_id}</td></tr>
        )}
        {paper.meta.replicates_doi && (
          <tr><td class="k">replicates doi</td><td class="v mono">{paper.meta.replicates_doi}</td></tr>
        )}
        {paper.meta.replication_url && (
          <tr>
            <td class="k">replication folder</td>
            <td class="v">
              <a href={paper.meta.replication_url} rel="noopener noreferrer" target="_blank">
                {paper.meta.replication_url}
              </a>
            </td>
          </tr>
        )}
        {paper.meta.revises_paper_id && (
          <tr><td class="k">revises</td><td class="v"><a href={`${import.meta.env.BASE_URL}papers/${paper.meta.revises_paper_id}/`}><code class="mono">{paper.meta.revises_paper_id}</code></a></td></tr>
        )}
        {paper.meta.desk_reviewed_at && (
          <tr><td class="k">desk_reviewed_at</td><td class="v"><code class="mono">{formatDate(paper.meta.desk_reviewed_at)}</code></td></tr>
        )}
        {paper.meta.decided_at && (
          <tr><td class="k">decided_at</td><td class="v"><code class="mono">{formatDate(paper.meta.decided_at)}</code></td></tr>
        )}
        {paper.meta.degraded_mode && (
          <tr><td class="k">degraded_mode</td><td class="v">reserve reviewers used: {paper.meta.degraded_mode.reserve_reviewers_used}</td></tr>
        )}
      </table>
    </div>
  </Tabs>
</BaseLayout>

<style>
  .paper-toc {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    max-width: min(640px, calc(100vw - 40px));
    max-height: calc(100vh - 40px);
    overflow: auto;
    z-index: 60;
    border: 1.5px solid var(--color-text);
    background: var(--color-bg);
    padding: 14px 18px;
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.18);
  }
  .paper-toc[hidden] { display: none; }
  .paper-toc-label {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #555;
    margin-bottom: 6px;
  }
  .paper-toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: paper-toc;
  }
  .paper-toc-list li {
    margin: 2px 0;
    font-size: 12px;
    line-height: 1.55;
    counter-increment: paper-toc;
  }
  .paper-toc-list li::before {
    content: counter(paper-toc) ". ";
    color: #888;
  }
  .paper-toc-list a {
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }
  .paper-toc-list a:hover,
  .paper-toc-list a:focus-visible {
    border-bottom-color: var(--color-text);
  }

  .paper-toc-toggle {
    position: fixed;
    top: 50%;
    right: 12px;
    transform: translateY(-50%);
    writing-mode: vertical-rl;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 14px 6px;
    background: var(--color-bg);
    color: var(--color-text);
    border: 1.5px solid var(--color-text);
    cursor: pointer;
    z-index: 50;
  }
  .paper-toc-toggle[aria-expanded="false"] {
    background: var(--color-text);
    color: var(--color-bg);
  }
  .paper-toc-toggle:focus-visible {
    outline: 2px solid var(--color-text);
    outline-offset: 2px;
  }

  .replication-link {
    margin: 12px 0 20px 0;
    font-family: var(--font-mono);
    font-size: 13px;
  }
  .replication-link a {
    display: inline-block;
    padding: 6px 12px;
    border: 1.5px solid var(--color-text);
    text-decoration: none;
    color: var(--color-text);
  }
  .replication-link a:hover,
  .replication-link a:focus-visible {
    background: var(--color-text);
    color: var(--color-bg);
  }

  @media (max-width: 1024px) {
    .paper-toc-toggle { display: none; }
    .paper-toc {
      position: static;
      transform: none;
      max-width: none;
      max-height: none;
      overflow: visible;
      box-shadow: none;
      margin: 16px 0 20px 0;
      padding: 10px 14px;
    }
    .paper-toc[hidden] { display: block; }
  }
</style>

<script>
  function setTocOpen(btn: HTMLButtonElement, panel: HTMLElement, open: boolean) {
    if (open) panel.removeAttribute("hidden");
    else panel.setAttribute("hidden", "");
    btn.setAttribute("aria-expanded", String(open));
  }
  for (const btn of document.querySelectorAll<HTMLButtonElement>("[data-toc-toggle]")) {
    const id = btn.getAttribute("aria-controls");
    if (!id) continue;
    const panel = document.getElementById(id);
    if (!panel) continue;
    btn.addEventListener("click", () => {
      setTocOpen(btn, panel, panel.hasAttribute("hidden"));
    });
    for (const a of panel.querySelectorAll<HTMLAnchorElement>("a")) {
      a.addEventListener("click", () => setTocOpen(btn, panel, false));
    }
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && !panel.hasAttribute("hidden")) {
        setTocOpen(btn, panel, false);
        btn.focus();
      }
    });
    document.addEventListener("pointerdown", (e) => {
      if (panel.hasAttribute("hidden")) return;
      const target = e.target as Node;
      if (panel.contains(target) || btn.contains(target)) return;
      setTocOpen(btn, panel, false);
    });
  }
</script>
