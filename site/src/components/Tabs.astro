---
export interface TabDef {
  id: string;
  label: string;
  count?: number | null;
}

export interface Props {
  tabs: TabDef[];
  defaultTab?: string;
}
const { tabs, defaultTab } = Astro.props;
const initial = defaultTab ?? tabs[0]?.id;

// Helper: is a given slot id included in the tabs list?
const hasTab = (id: string) => tabs.some((t) => t.id === id);
---
<div class="tabs" role="tablist">
  {tabs.map((t) => (
    <button
      role="tab"
      id={`tab-${t.id}`}
      aria-controls={`panel-${t.id}`}
      aria-selected={t.id === initial ? "true" : "false"}
      data-tab-id={t.id}
    >
      {t.label}
      {typeof t.count === "number" && <span class="count">({t.count})</span>}
    </button>
  ))}
</div>

{hasTab("manuscript") && (
  <section
    class="tabpanel"
    role="tabpanel"
    id="panel-manuscript"
    aria-labelledby="tab-manuscript"
    hidden={"manuscript" !== initial}
  >
    <slot name="manuscript" />
  </section>
)}

{hasTab("reviews") && (
  <section
    class="tabpanel"
    role="tabpanel"
    id="panel-reviews"
    aria-labelledby="tab-reviews"
    hidden={"reviews" !== initial}
  >
    <slot name="reviews" />
  </section>
)}

{hasTab("decision") && (
  <section
    class="tabpanel"
    role="tabpanel"
    id="panel-decision"
    aria-labelledby="tab-decision"
    hidden={"decision" !== initial}
  >
    <slot name="decision" />
  </section>
)}

{hasTab("metadata") && (
  <section
    class="tabpanel"
    role="tabpanel"
    id="panel-metadata"
    aria-labelledby="tab-metadata"
    hidden={"metadata" !== initial}
  >
    <slot name="metadata" />
  </section>
)}

<script>
  // Tabs: single event listener on each tablist; toggles aria-selected + hidden.
  for (const list of document.querySelectorAll<HTMLElement>('[role="tablist"]')) {
    list.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      const tab = target.closest<HTMLElement>('[role="tab"]');
      if (!tab || !list.contains(tab)) return;
      const chosen = tab.dataset.tabId;
      if (!chosen) return;
      for (const t of list.querySelectorAll<HTMLElement>('[role="tab"]')) {
        t.setAttribute("aria-selected", t.dataset.tabId === chosen ? "true" : "false");
      }
      const container = list.parentElement;
      if (!container) return;
      for (const p of container.querySelectorAll<HTMLElement>('[role="tabpanel"]')) {
        p.hidden = p.id !== `panel-${chosen}`;
      }
    });
  }
</script>
