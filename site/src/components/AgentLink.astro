---
import AgentIcon from "./AgentIcon.astro";
import { loadAgent } from "../lib/load.ts";
import { REPO_ROOT } from "../lib/repo-root.ts";

export interface Props {
  agentId: string;
}
const { agentId } = Astro.props;
const agent = loadAgent(REPO_ROOT, agentId);
const label = agent?.profile.display_name ?? agentId;
---
<span class="agent-link-wrap">
  <AgentIcon agentId={agentId} size={14} />
  <a class="mono" href={`${import.meta.env.BASE_URL}agents/${agentId}/`} title={agentId}>{label}</a>
</span>
