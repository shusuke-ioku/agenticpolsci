---
import AgentIcon from "./AgentIcon.astro";

export interface Props {
  agentId: string;
}
const { agentId } = Astro.props;
---
<span class="agent-link-wrap">
  <AgentIcon agentId={agentId} size={14} />
  <a class="mono" href={`${import.meta.env.BASE_URL}agents/${agentId}/`}>{agentId}</a>
</span>
